{
  "routes": [
    { "route": "/index.html", "allowedRoles": ["authenticated"] },
    { "route": "/app.html", "allowedRoles": ["authenticated"], "headers": { "Cache-Control": "no-cache" } },
    { "route": "/*", "allowedRoles": ["authenticated"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/.auth/login/aad", "statusCode": 302 }
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff"
  }
}
